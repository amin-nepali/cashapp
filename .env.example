# TikTok Profile Scraper Environment Variables

# Server Port (default: 3001)
PORT=3001

# Node Environment
NODE_ENV=development

# TikTok API Configuration
TIKTOK_TIMEOUT=10000
TIKTOK_RATE_LIMIT=100

# CORS Settings
CORS_ORIGIN=http://localhost:3000,http://localhost:5174,http://localhost:8080

# For production use
# PORT=3001
# NODE_ENV=production
# CORS_ORIGIN=https://yourdomain.com
